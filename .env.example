# Copy this file to .env and set your values.
# .env is not committed to version control.

# -------------------------------------------------------
# WORKSPACE_FOLDER
# The name of the folder inside WORKSPACE_BASE to mount.
# Only this folder will be accessible inside the container.
#
# Example: if your project lives at ~/projects/my-app
# set WORKSPACE_FOLDER=my-app
# -------------------------------------------------------
WORKSPACE_FOLDER=

# -------------------------------------------------------
# WORKSPACE_BASE (optional)
# The parent directory on your Mac that contains your projects.
# Defaults to ~/projects if not set.
# -------------------------------------------------------
WORKSPACE_BASE=~/projects
